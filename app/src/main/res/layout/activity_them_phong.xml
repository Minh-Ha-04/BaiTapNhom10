<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- Header form -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1565C0"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Thông Tin Phòng"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card thông tin cơ bản -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THÔNG TIN CƠ BẢN"
                        android:textColor="#90A4AE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mã phòng *"
                        android:textColor="#37474F"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <EditText android:id="@+id/etMaPhong"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="VD: P05"
                        android:paddingHorizontal="14dp"
                        android:inputType="text"
                        android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên phòng *"
                        android:textColor="#37474F"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <EditText android:id="@+id/etTenPhong"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="VD: Phòng 301"
                        android:paddingHorizontal="14dp"
                        android:inputType="text"
                        android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá thuê (đồng/tháng) *"
                        android:textColor="#37474F"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <EditText android:id="@+id/etGiaThue"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="VD: 3000000"
                        android:paddingHorizontal="14dp"
                        android:inputType="numberDecimal"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card tình trạng -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TÌNH TRẠNG PHÒNG"
                        android:textColor="#90A4AE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp"/>

                    <CheckBox android:id="@+id/cbDaThue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="  Phòng đã có người thuê"
                        android:textSize="15sp"
                        android:textColor="#37474F"
                        android:buttonTint="#1565C0"/>

                    <!-- Thông tin người thuê -->
                    <LinearLayout android:id="@+id/layoutNguoiThue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="14dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E8EAF6"
                            android:layout_marginBottom="14dp"/>

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tên người thuê *"
                            android:textColor="#37474F"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etTenNguoiThue"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext"
                            android:hint="Họ và tên đầy đủ"
                            android:paddingHorizontal="14dp"
                            android:inputType="textPersonName"
                            android:layout_marginBottom="14dp"/>

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số điện thoại *"
                            android:textColor="#37474F"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etSoDienThoai"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext"
                            android:hint="VD: 0901234567"
                            android:paddingHorizontal="14dp"
                            android:inputType="phone"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <Button android:id="@+id/btnHuy"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Hủy"
                    android:textColor="#546E7A"
                    android:background="@drawable/bg_button_secondary"
                    android:layout_marginEnd="8dp"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <Button android:id="@+id/btnThem"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="2"
                    android:text="Thêm phòng"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>